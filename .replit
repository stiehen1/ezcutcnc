modules = ["nodejs-20", "web", "python-3.11", "postgresql-16"]
run = "node dist/index.cjs"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-24_05"
packages = ["glibcLocales", "psmisc"]

[[ports]]
localPort = 5000
externalPort = 80

[env]
PORT = "5000"

# Reserved VM (always-on), not autoscale: PDF→Claude extraction holds one
# connection open for several seconds. Autoscale was SIGTERM-killing the
# process mid-request (container recycle / scale-to-zero), dropping the
# connection so the client showed "Print read timed out" regardless of
# file size or timeout values. Reserved VM has no per-request kill.
[deployment]
deploymentTarget = "gce"
run = ["node", "./dist/index.cjs"]
build = ["npm", "run", "build"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

# Build first, then free port 5000 and serve a SINGLE listener.
# Why the port dance: the Run button and any prior supervisor process both try to
# own 5000. Starting `node dist/index.cjs` while an old listener is still bound
# races and dies with EADDRINUSE (exactly the crash seen on redeploy). `fuser -k`
# alone is unreliable — the old proc can outlive a fixed `sleep 2`. So kill, then
# WAIT in a loop until the kernel reports 5000 actually free before starting.
[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run build && fuser -k 5000/tcp 2>/dev/null || true; for i in $(seq 1 30); do fuser 5000/tcp >/dev/null 2>&1 || break; sleep 0.5; done; exec node dist/index.cjs"
waitForPort = 5000

[agent]
expertMode = true
