modules = ["nodejs-20", "web", "python-3.11", "postgresql-16"]
run = "node dist/index.cjs"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-24_05"
packages = ["glibcLocales"]

[[ports]]
localPort = 5000
externalPort = 80

[env]
PORT = "5000"

# Reserved VM (always-on), not autoscale: PDF→Claude extraction holds one
# connection open for several seconds. Autoscale was SIGTERM-killing the
# process mid-request (container recycle / scale-to-zero), dropping the
# connection so the client showed "Print read timed out" regardless of
# file size or timeout values. Reserved VM has no per-request kill.
[deployment]
deploymentTarget = "gce"
run = ["node", "./dist/index.cjs"]
build = ["npm", "run", "build"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run build && node dist/index.cjs"
waitForPort = 5000
